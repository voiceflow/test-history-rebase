{
  "$": {
    "combine": ["specials", "ignores"]
  },
  "specials": ["bin", "eslint", "webpack", "jest", "babel"],
  "ignores": [
    "@svgr/webpack",
    "@hot-loader/react-dom",
    "@commitlint/*",
    "@voiceflow/*",
    "@types/*",
    "@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser",
    "stylelint*",
    "babel-*",
    "eslint-*",
    "css-loader",
    "postcss-loader",
    "file-loader",
    "style-loader",
    "pathfinding",
    "is-color-stop",
    "jest-pnp-resolver",
    "identity-obj-proxy",
    "fixpack",
    "husky",
    "lint-staged",
    "cz-conventional-changelog",
    "prettier",
    "prettier-eslint",
    "prettier-eslint-cli",
    "prettier-stylelint",
    "react-router",
    "exargs",
    "@storybook/addon-docs",
    "@storybook/addon-storyshots",
    "jest-styled-components",
    "lodash-es",
    "ignore-styles",
    "mock-local-storage",
    "nyc",
    "typescript"
  ]
}
