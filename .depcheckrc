{
  "specials": ["bin", "eslint", "lint-staged", "istanbul", "commitizen", "husky", "prettier", "ttypescript", "webpack", "jest", "babel"],
  "ignores": [
    "@svgr/webpack",
    "@hot-loader/react-dom",
    "@commitlint/*",
