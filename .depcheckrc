{
  "$": {
    "combine": ["specials", "ignores"]
  },
  "specials": ["bin", "eslint", "webpack", "jest", "babel"],
  "ignores": [
    "@svgr/webpack",
    "@hot-loader/react-dom",
    "@commitlint/*",
    "@voiceflow/*",
    "@types/*",
    "@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser",
    "stylelint*",
    "babel-*",
    "@babel/preset-es2015",
    "@babel/preset-typescript",
    "eslint-*",
    "css-loader",
    "postcss-loader",
    "file-loader",
    "style-loader",
    "identity-obj-proxy",
    "fixpack",
    "husky",
    "lint-staged",
    "cz-conventional-changelog",
    "prettier",
    "prettier-eslint",
    "prettier-eslint-cli",
    "prettier-stylelint",
    "exargs",
    "lodash-es",
    "ignore-styles",
    "mock-local-storage",
    "istanbul-instrumenter-loader",
    "tslib",
    "ts-loader",
    "node-noop"
  ]
}
