  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged",
      "pre-push": "git-branch-check"
    }
  },
  "lint-staged": {
    "package.json": [
      "fixpack",
      "git add"
    ],
    "**/*.{js,jsx}": [
      "eslint --fix",
      "prettier-eslint --write",
      "git add"
    ],
    "**/*.css": [
      "prettier-stylelint"
    ]
  },
  "prettier": "@voiceflow/prettier-config",
  "release": {
    "branch": "production"
  },
  "scripts": {
    "build": "patch-package && wp --prod",
    "build:admin": "wp --action=admin --prod",
    "build:dev": "patch-package && wp",
    "commit": "scripts/change_remote.sh && git-cz",
    "demo": "scripts/apply_demo_env.sh && wp --action=serve",
    "deploy:staging": "git push origin $(git branch | grep \\* | cut -d ' ' -f2):staging -f",
    "gen-certs": "scripts/generate_certs.sh",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:css": "stylelint src/**/*.css",
    "lint:js": "eslint \"src/**/*.{js,jsx}\"",
    "lint:quiet": "npm run lint:js -- --quiet && npm run lint:css -- --quiet",
    "postinstall": "patch-package",
    "preview": "scripts/deploy_ephemeral.sh",
    "preview:delete": "scripts/delete_ephemeral.sh",
    "start": "scripts/apply_local_env.sh && wp --action=serve",
    "start:admin": "wp --action=admin-serve",
    "storybook": "start-storybook --https --ssl-cert=certs/localhost.crt --ssl-key=certs/localhost.key",
    "storybook:build": "build-storybook --output-dir storybook_build --quiet",
    "tdd": "npm run test -- --watchAll=true",
    "test": "NODE_ENV=test jest",
    "test:dependencies": "depcheck $(exargs .depcheckrc)"
  }
}
