{
  "name": "root",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "16.1.0",
    "@istanbuljs/nyc-config-typescript": "1.0.1",
    "@types/chai": "4.3.0",
    "@types/chai-as-promised": "7.1.4",
    "@types/deep-equal-in-any-order": "1.0.1",
    "@types/mock-require": "2.0.1",
    "@types/sinon": "10.0.8",
    "@types/sinon-chai": "3.2.8",
    "@voiceflow/babel-preset": "1.1.1",
    "@voiceflow/commitlint-config": "1.1.1",
    "@voiceflow/eslint-config": "3.5.0",
    "@voiceflow/git-branch-check": "1.2.3",
    "@voiceflow/prettier-config": "1.0.6",
    "@voiceflow/semantic-release-config": "1.0.9",
    "@voiceflow/stylelint-config": "1.0.1",
    "@voiceflow/tsconfig": "1.2.5",
    "@voiceflow/webpack-config": "1.10.0",
    "@zerollup/ts-transform-paths": "1.7.18",
    "chai": "4.3.4",
    "chai-as-promised": "7.1.1",
    "commitizen": "4.2.4",
    "concurrently": "7.0.0",
    "cz-conventional-changelog": "2.1.0",
    "deep-equal-in-any-order": "1.1.15",
    "depcheck": "1.4.3",
    "eslint": "7.32.0",
    "eslint-import-resolver-lerna": "2.0.0",
    "eslint-import-resolver-webpack": "0.13.1",
    "fixpack": "4.0.0",
    "husky": "7.0.4",
    "lerna": "4.0.0",
    "lint-staged": "11.1.2",
    "mocha": "9.1.4",
    "mocha-suite": "1.0.11",
    "mock-require": "3.0.3",
    "node-dev": "7.0.0",
    "nodemon": "2.0.13",
    "nyc": "15.1.0",
    "prettier": "2.4.1",
    "prettier-stylelint": "0.4.2",
    "react-hot-loader": "4.13.0",
    "rimraf": "3.0.2",
    "sinon": "11.1.2",
    "sinon-chai": "3.7.0",
    "stylelint": "13.13.1",
    "ts-mocha": "8.0.0",
    "ts-node": "10.4.0",
    "tsconfig-paths": "3.12.0",
    "ttypescript": "1.5.12",
    "typescript": "4.4.4",
    "webpack": "5.62.1",
    "webpack-nano": "1.1.1"
  },
  "prettier": "@voiceflow/prettier-config",
  "private": true,
  "scripts": {
    "bootstrap": "lerna bootstrap --no-ci",
    "build": "lerna run build --concurrency=4 --stream",
    "build:deps": "yarn build --scope @voiceflow/ui --scope @voiceflow/socket-utils --scope @voiceflow/realtime-sdk --scope @voiceflow/ml-sdk",
    "clean": "yarn clean:artifacts && yarn clean:root",
    "clean:artifacts": "lerna run clean --parallel",
    "clean:root": "rimraf node_modules",
    "commit": "cz",
    "connect:cli": "yarn --cwd packages/creator-app connect:cli",
    "cypress": "yarn --cwd packages/creator-app cypress",
    "cypress:ci": "yarn --cwd packages/creator-app cypress:ci",
    "cypress:install": "yarn --cwd packages/creator-app cypress:install",
    "dev": "lerna run dev --concurrency=4 --parallel",
    "e2e": "yarn --cwd packages/creator-app e2e",
    "e2e:check-deps": "yarn --cwd packages/creator-app e2e:check-deps",
    "e2e:check-deps-ci": "yarn --cwd packages/creator-app e2e:check-deps-ci",
    "gen-certs:e2e": "yarn --cwd packages/creator-app gen-certs:e2e",
    "kill:e2e": "yarn --cwd packages/creator-app kill:e2e",
    "lint": "lerna run lint --concurrency=4 --parallel",
    "lint:dockerfiles": "lerna run lint:dockerfiles --concurrency=4 --parallel",
    "lint:fix": "lerna run lint:fix --concurrency=4 --parallel",
    "lint:quiet": "lerna run lint:quiet --concurrency=4 --parallel",
    "lint:report": "lerna run lint:report --concurrency=4 --parallel",
    "local": "yarn --cwd packages/creator-app local",
    "local:admin-ui": "yarn --cwd packages/admin-app local",
    "local:creator-app": "yarn --cwd packages/creator-app local",
    "local:e2e": "yarn --cwd packages/creator-app local:e2e",
    "local:ml-gateway": "yarn --cwd packages/ml-gateway local",
    "local:realtime": "yarn --cwd packages/realtime local",
    "mesh:post:admin-ui": "yarn --cwd packages/admin-app mesh:post",
    "mesh:post:creator-app": "yarn --cwd packages/creator-app mesh:post",
    "mesh:post:ml-gateway": "yarn --cwd packages/ml-gateway mesh:post",
    "mesh:post:realtime": "yarn --cwd packages/realtime mesh:post",
    "mesh:pre:admin-ui": "yarn --cwd packages/admin-app mesh:pre",
    "mesh:pre:creator-app": "yarn --cwd packages/creator-app mesh:pre",
    "mesh:pre:ml-gateway": "yarn --cwd packages/ml-gateway mesh:pre",
    "mesh:pre:realtime": "yarn --cwd packages/realtime mesh:pre",
    "postinstall": "yarn bootstrap",
    "prepare": "husky install",
    "start": "yarn --cwd packages/creator-app start",
    "start:admin": "yarn --cwd packages/admin-app start",
    "start:e2e": "yarn --cwd packages/creator-app start:e2e",
    "start:hidden": "yarn --cwd packages/creator-app start:hidden",
    "start:meshed": "yarn --cwd packages/creator-app start:meshed",
    "start:meshed:admin-ui": "yarn --cwd packages/admin-app start:meshed",
    "start:meshed:creator-app": "yarn --cwd packages/creator-app start:meshed",
    "start:meshed:ml-gateway": "yarn --cwd packages/ml-gateway start:meshed",
    "start:meshed:realtime": "yarn --cwd packages/realtime start:meshed",
    "start:proxy": "yarn --cwd packages/creator-app start:proxy",
    "test": "lerna run test --concurrency=4 --parallel",
    "test:dependencies": "lerna run test:dependencies --concurrency=4 --parallel",
    "test:integration": "lerna run test:integration --concurrency=4 --parallel",
    "test:run": "lerna run test:run --concurrency=4 --parallel",
    "test:unit": "lerna run test:unit --concurrency=4 --parallel"
  },
  "workspaces": [
    "packages/*"
  ]
}
