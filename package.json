{
  "name": "@voiceflow/creator",
  "description": "Voiceflow UI and API for UI",
  "version": "1.0.1",
  "author": "Voiceflow",
  "bugs": "https://voiceflow.atlassian.net/projects/CORE/issues/",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.0.16",
    "@sendgrid/mail": "^6.3.1",
    "@voiceflow/common": "^1.1.2",
    "@voiceflow/verror": "^1.1.0",
    "@xtrctio/express-bunyan-logger": "^1.3.3",
    "adm-zip": "^0.4.13",
    "analytics-node": "^3.3.0",
    "auto-bind": "^2.1.0",
    "aws-sdk": "^2.455.0",
    "axios": "^0.18.0",
    "babel-core": "7.0.0-bridge.0",
    "bcrypt": "^3.0.4",
    "bluebird": "^3.5.4",
    "body-parser": "^1.18.3",
    "bunyan": "^1.8.12",
    "bunyan-prettystream": "^0.1.3",
    "compression": "^1.7.4",
    "concurrently": "^4.0.1",
    "cookie-parser": "^1.4.3",
    "cors": "^2.8.4",
    "del": "^3.0.0",
    "dialogflow": "^0.8.0",
    "dotenv": "^8.0.0",
    "elasticsearch": "^15.4.1",
    "express": "^4.16.4",
    "fluent-ffmpeg": "^2.1.2",
    "google-auth-library": "^2.0.2",
    "hashids": "^1.2.2",
    "helmet": "^3.14.0",
    "history": "^4.7.2",
    "http-aws-es": "^6.0.0",
    "http-status": "^1.3.2",
    "intercom-client": "^2.10.4",
    "is-var-name": "^2.0.0",
    "jsonwebtoken": "^8.3.0",
    "lodash": "^4.17.11",
    "logdna-bunyan": "^1.1.0",
    "mkdirp": "^0.5.1",
    "moment": "^2.24.0",
    "morgan": "^1.9.1",
    "moxios": "^0.4.0",
    "multer": "^1.4.1",
    "multer-s3": "^2.7.0",
    "multer-s3-transform": "^2.3.2",
    "passport": "^0.4.0",
    "passport-local": "^1.0.0",
    "pg": "^7.11.0",
    "randomstring": "^1.1.5",
    "redis": "^2.8.0",
    "rotating-file-stream": "^1.4.0",
    "s3-upload-stream": "^1.0.7",
    "safe-json-stringify": "^1.2.0",
    "sharp": "^0.22.1",
    "socket.io": "^2.2.0",
    "socket.io-client": "^2.2.0",
    "socket.io-redis": "^5.2.0",
    "stacktrace-js": "^2.0.0",
    "string-similarity": "^3.0.0",
    "stripe": "^6.34.0",
    "uuid": "^3.3.2",
    "valid-url": "^1.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.3.3",
    "@commitlint/cli": "^7.6.1",
    "@commitlint/config-conventional": "^7.5.0",
    "@voiceflow/database": "^1.1.3",
    "@voiceflow/eslint-config": "0.0.1",
    "chai": "^4.2.0",
    "commitizen": "^3.1.1",
    "cz-conventional-changelog": "^2.1.0",
    "dynamodb-migrations": "0.0.10",
    "eslint": "^5.16.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-config-airbnb-base": "^13.1.0",
    "eslint-plugin-import": "^2.17.2",
    "eslint-plugin-jsx-a11y": "^6.2.1",
    "eslint-plugin-mocha": "^5.2.1",
    "eslint-plugin-react": "^7.12.4",
    "fixpack": "^2.3.1",
    "husky": "^2.3.0",
    "jest": "^24.8.0",
    "knex": "^0.16.7",
    "knex-cleaner": "^1.1.4",
    "mocha": "^6.1.4",
    "nyc": "^14.1.1",
    "prettier": "^1.17.1",
    "pretty-quick": "^1.10.0",
    "redis-mock": "^0.44.0",
    "semantic-release": "^15.13.12",
    "sinon": "^7.3.2",
    "supertest": "^4.0.2"
  },
  "homepage": "https://creator.getvoiceflow.com",
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "fixpack && git add package.json && git commit --amend -C HEAD --no-verify && pretty-quick --staged"
    }
  },
  "jest": {
    "setupFiles": [
      "./scripts/setupFile.js"
    ]
  },
  "keywords": [
    "api",
    "ui"
  ],
  "license": "ISC",
  "main": "index.js",
  "release": {
    "branch": "production"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/storyflow/storyflow-creator"
  },
  "scripts": {
    "build": "cd app && npm run build",
    "client": "cd app && npm run start",
    "commit": "git-cz",
    "debug": "node --inspect-brk index.js",
    "dev": "concurrently --kill-others-on-fail \"npm run local\" \"npm run client\"",
    "elasticsearch": "elasticsearch",
    "integration": "NODE_ENV=test node tests/server/init-old-integration.js && NODE_ENV=test mocha --use_strict --exit \"tests/**/*.it.js\"",
    "lint": "eslint \"**/*.js\" --fix",
    "local": "NODE_ENV=local node index.js",
    "old-integration": "NODE_ENV=test node tests/server/init-old-integration.js && mocha --use_strict --exit \"tests/**/*.old-it.js\"",
    "old-unit": "NODE_ENV=test npx jest --testPathIgnorePatterns=/app/ --detectOpenHandles --runInBand --testMatch=\"**/(*.)+(test).js?(x)\"",
    "prod": "NODE_ENV=development_prod node index.js",
    "prod_test": "NODE_ENV=development_prod_test node index.js",
    "redis": "redis-server",
    "staging": "NODE_ENV=staging node index.js",
    "start": "NODE_ENV=production node index.js",
    "test": "NODE_ENV=test node tests/server/init-old-integration.js && NODE_ENV=test nyc mocha --use_strict --exit \"tests/**/*.old-it.js\" \"tests/**/*.unit.js\" \"tests/**/*.it.js\"",
    "unit": "NODE_ENV=test mocha --use_strict --exit \"tests/**/*.unit.js\"",
    "unsecure": "node index.js",
    "update": "npm install && cd app && npm install"
  }
}
