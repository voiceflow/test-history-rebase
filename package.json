    "babel-core": "7.0.0-bridge.0",
    "bcrypt": "^3.0.4",
    "body-parser": "^1.18.3",
    "concurrently": "^4.0.1",
    "cookie-parser": "^1.4.3",
    "cors": "^2.8.4",
    "del": "^3.0.0",
    "dialogflow": "^0.8.0",
    "dotenv": "^6.2.0",
    "express": "^4.16.4",
    "fluent-ffmpeg": "^2.1.2",
    "google-auth-library": "^2.0.2",
    "hashids": "^1.2.2",
    "helmet": "^3.14.0",
    "history": "^4.7.2",
    "http-proxy": "^1.17.0",
