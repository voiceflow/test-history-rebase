  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged",
      "pre-push": "git-branch-check"
    }
  },
  "license": "UNLICENSED",
  "lint-staged": {
    "package.json": [
      "fixpack"
    ],
    "**/*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier-eslint --write"
    ],
    "**/*.css": [
      "prettier-stylelint"
    ],
    "Dockerfile": [
      "hadolint --ignore DL3018"
    ],
    "*.dockerfile": [
      "hadolint --ignore DL3018"
    ]
  },
  "prettier": "@voiceflow/prettier-config",
  "scripts": {
    "build": "patch-package && wp --prod",
    "build:admin": "wp --action admin --prod",
    "build:dev": "patch-package && wp",
    "build:e2e": "patch-package && wp --instrument",
    "commit": "cz",
    "cypress": "NODE_ENV=test cypress open",
    "cypress:ci": "NODE_ENV=test cypress run --env CI=true --config defaultCommandTimeout=20000",
    "cypress:run": "NODE_ENV=test cypress run",
    "deploy:staging": "git push origin $(git branch | grep \\* | cut -d ' ' -f2):staging -f",
    "gen-certs": "scripts/generate_certs.sh",
    "gen-certs:e2e": "scripts/generate_e2e_certs.sh",
    "lint": "yarn lint:js && yarn lint:css",
    "lint:css": "stylelint src/**/*.css",
    "lint:dockerfiles": "hadolint --ignore DL3018 ./Dockerfile ./cache.dockerfile ./admin.dockerfile ./storybook.dockerfile",
    "lint:js": "eslint \"src/**/*.{js,ts,jsx,tsx}\"",
    "lint:js:fix": "eslint \"src/**/*.{js,ts,jsx,tsx}\" --fix --rule 'react-hooks/exhaustive-deps: off'",
    "lint:quiet": "yarn lint:js --quiet && yarn lint:css --quiet",
    "local": "yarn start",
    "local:admin": "yarn start:admin",
    "postinstall": "patch-package",
    "preview:check": "echo \"creatorapp\"",
    "preview:new": "scripts/deploy_dev_environments.sh",
    "start": "wp --action serve",
    "start:admin": "wp --action admin-serve",
    "start:hidden": "wp --action serve --no-open",
    "storybook": "start-storybook --https --ssl-cert=certs/localhost.crt --ssl-key=certs/localhost.key --static-dir=public",
    "storybook:build": "build-storybook --output-dir storybook_build --static-dir=public --quiet",
    "tdd:integration": "yarn test:integration --watchAll=true",
    "tdd:unit": "NODE_ENV=test nyc --reporter=text ts-mocha --watch --watch-extensions js,jsx,ts,tsx --paths --config config/test/unit/mocharc.yml",
    "test": "yarn test:unit && yarn test:integration",
    "test:dependencies": "depcheck $(exargs .depcheckrc)",
    "test:integration": "NODE_ENV=test jest --config config/test/integration/jest.config.js",
    "test:unit": "NODE_ENV=test nyc ts-mocha --paths --config config/test/unit/mocharc.yml"
  }
}
