{
  "name": "storyflow-creator",
  "jest": {
    "setupFiles": ["./scripts/setupFile.js"]
  },
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "tests": "./scripts/test.sh",
    "integration_tests": "NODE_ENV=test ./node_modules/.bin/jest --testPathIgnorePatterns=/app/ --detectOpenHandles --runInBand --forceExit --testMatch=\"**/(*.)+(itest).js?(x)\"",
    "unit_tests": "NODE_ENV=test ./node_modules/.bin/jest --testPathIgnorePatterns=/app/ --detectOpenHandles --testMatch=\"**/(*.)+(test).js?(x)\"",
    "build": "cd app && npm run build",
    "start": "NODE_ENV=production node index.js",
    "prod": "NODE_ENV=development_prod node index.js",
    "prod_test": "NODE_ENV=development_prod_test node index.js",
    "local": "NODE_ENV=local node index.js",
    "debug": "node --inspect-brk index.js",
    "unsecure": "node index.js",
    "staging": "NODE_ENV=staging node index.js",
    "client": "cd app && npm run start",
    "redis": "redis-server",
    "update": "npm install && cd app && npm install",
    "dev": "concurrently --kill-others-on-fail \"npm run local\" \"npm run client\""
  },
  "repository": {
    "type": "git",
    "url": "git@api.getstoryflow.com:storyflow-creator"
  },
  "author": "",
  "license": "ISC",
