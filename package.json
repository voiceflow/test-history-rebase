  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "resolutions": {
    "immutable": "3.8.2"
  },
  "scripts": {
    "build": "patch-package && wp --prod",
    "build:admin": "wp --action admin --prod",
    "build:dev": "patch-package && wp",
    "build:e2e": "patch-package && wp --instrument",
    "commit": "cz",
    "cypress": "NODE_ENV=test cypress open",
    "cypress:ci": "NODE_ENV=test cypress run --env CI=true --config defaultCommandTimeout=20000",
    "cypress:run": "NODE_ENV=test cypress run",
    "deploy:staging": "git push origin $(git branch | grep \\* | cut -d ' ' -f2):staging -f",
    "dev-server": "node server",
    "gen-certs": "scripts/generate_certs.sh",
    "gen-certs:e2e": "scripts/generate_e2e_certs.sh",
    "lint": "yarn lint:js && yarn lint:css",
    "lint:css": "stylelint src/**/*.css",
    "lint:dockerfiles": "hadolint --ignore DL3018 ./app.dockerfile ./admin.dockerfile ./packages/storybook/dockerfile",
    "lint:js": "eslint \"src/**/*.{js,ts,jsx,tsx}\"",
    "lint:js:fix": "yarn lint:js --fix --rule 'react-hooks/exhaustive-deps: off'",
    "lint:quiet": "yarn lint:js --rule 'prettier/prettier: off' --quiet && yarn lint:css --quiet",
    "lint:report": "yarn lint:js --format json -o sonar/report.json && yarn lint:css --formatter json --output-file sonar/report_css.json",
    "local": "yarn start --typecheck",
    "local:admin": "yarn start:admin",
    "postinstall": "patch-package",
    "preview:check": "echo \"creatorapp\"",
    "preview:new": "scripts/deploy_dev_environments.sh",
    "start": "yarn dev-server --action serve",
    "start:admin": "yarn dev-server --action admin-serve",
    "start:hidden": "yarn start --no-open",
    "tdd:integration": "yarn test:integration --watchAll=true",
    "tdd:unit": "NODE_ENV=test ts-mocha --project tsconfig.test.json --paths --watch --config config/test/unit/mocharc.yml",
    "test": "yarn test:unit && yarn test:integration",
    "test:dependencies": "depcheck",
    "test:integration": "NODE_ENV=test jest --config config/test/integration/jest.config.js",
    "test:unit": "NODE_ENV=test nyc ts-mocha --project tsconfig.test.json --paths --config config/test/unit/mocharc.yml",
    "types": "tsc --project tsconfig.build.json --noEmit --skipLibCheck"
  }
}
