{
  "name": "@voiceflow/admin-app",
  "version": "1.27.13",
  "author": "Voiceflow",
  "bugs": {
    "url": "https://github.com/voiceflow/creator-app/issues"
  },
  "dependencies": {
    "@sentry/react": "6.16.1",
    "@sentry/tracing": "6.16.1",
    "@voiceflow/api-sdk": "3.12.0",
    "@voiceflow/base-types": "2.19.0",
    "@voiceflow/common": "7.26.0",
    "@voiceflow/internal": "2.2.3",
    "@voiceflow/realtime-sdk": "^1.75.2",
    "@voiceflow/ui": "^1.71.4",
    "@voiceflow/voiceflow-types": "3.7.3",
    "axios": "0.24.0",
    "bootstrap": "4.6.1",
    "classnames": "2.3.1",
    "dayjs": "1.10.7",
    "history": "5.1.0",
    "lodash": "4.17.21",
    "markdown-to-jsx": "6.11.4",
    "moize": "5.4.7",
    "query-string": "7.1.0",
    "react": "17.0.2",
    "react-day-picker": "7.4.10",
    "react-dom": "17.0.2",
    "react-google-login": "4.0.1",
    "react-redux": "7.2.5",
    "react-router-dom": "6.1.1",
    "react-select": "3.2.0",
    "react-tippy": "1.4.0",
    "react-toastify": "5.5.0",
    "reactstrap": "8.10.1",
    "recompose": "0.30.0",
    "redux": "4.1.2",
    "redux-first-history": "5.0.7",
    "redux-thunk": "2.4.1",
    "reselect": "4.0.0",
    "stream-browserify": "3.0.0",
    "styled-components": "5.3.3",
    "universal-cookie": "4.0.4"
  },
  "devDependencies": {
    "@voiceflow/vite-config": "1.4.1",
    "vite": "2.9.0"
  },
  "files": [
    "build"
  ],
  "homepage": "https://github.com/voiceflow/creator-app#readme",
  "license": "UNLICENSED",
  "main": "build/index.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "scripts": {
    "analyze:dependencies": "depcruise --validate -- src",
    "build": "./scripts/build.sh",
    "build:dev": "SOURCE_MAPS=true vite build",
    "build:e2e": "VF_APP_BUILD_ENV=e2e VF_APP_E2E=true vite build",
    "clean:build": "rm -rf build",
    "connect:cli": "vfcli mesh connect admin-ui -c \"/bin/bash\"",
    "e2e": "yarn kill:e2e && concurrently -c yellow,blue \"VF_APP_E2E=true VF_APP_BUILD_ENV=e2e vite build --watch\" \"VF_APP_E2E=true vite preview --port 3002\"",
    "e2e:check-deps": "npx wait-on https://localhost:8003/health ",
    "e2e:check-deps-ci": "npx wait-on https://creator-api.test.e2e:8003/health",
    "gen-certs:e2e": "scripts/generate_e2e_certs.sh",
    "kill:e2e": "npx kill-port 3003 || true",
    "kill:process": "yarn kill:e2e",
    "lint": "concurrently -c yellow,blue,magenta \"yarn:lint:js\" \"yarn:lint:css\" \"yarn:lint:dockerfiles\"",
    "lint:css": "stylelint src/**/*.css",
    "lint:dockerfiles": "hadolint --ignore DL3018 ./Dockerfile",
    "lint:fix": "yarn lint:js --fix",
    "lint:js": "eslint \"**/*.{js,ts,jsx,tsx}\"",
    "lint:quiet": "concurrently -c yellow,blue \"yarn:lint:js --rule 'prettier/prettier: off' --quiet\" \"yarn:lint:css --quiet\" --color",
    "lint:report": "yarn lint:js --format json -o sonar/report.json && yarn lint:css --formatter json --output-file sonar/report_css.json",
    "local": "yarn kill:process && vfcli mesh connect admin-ui",
    "local:e2e": "yarn kill:e2e && VF_APP_E2E=true VF_APP_BUILD_ENV=e2e vite",
    "mesh:post": "exit 0",
    "mesh:pre": "exit 0",
    "start": "NODE_ENV=development vite",
    "start:e2e": "scripts/start_e2e.sh",
    "start:hidden": "yarn start --no-open",
    "start:meshed": "scripts/generate_certs.sh && yarn start",
    "start:proxy": "scripts/generate_certs.sh && docker compose up -d proxy",
    "test": "exit 0",
    "test:dependencies": "depcheck",
    "test:integration": "exit 0",
    "test:unit": "exit 0",
    "types": "tsc --project tsconfig.build.json --noEmit --skipLibCheck"
  }
}
