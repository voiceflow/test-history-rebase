{
  "name": "@voiceflow/admin-app",
  "version": "1.8.8",
  "author": "Voiceflow",
  "bugs": {
    "url": "https://github.com/voiceflow/creator-app/issues"
  },
  "dependencies": {
    "@sentry/react": "6.5.0",
    "@sentry/tracing": "6.5.0",
    "@voiceflow/api-sdk": "3.1.0",
    "@voiceflow/common": "7.6.1",
    "@voiceflow/general-types": "^3.0.3",
    "@voiceflow/internal": "2.1.0",
    "@voiceflow/realtime-sdk": "^1.37.2",
    "@voiceflow/ui": "^1.32.0",
    "axios": "0.21.4",
    "bootstrap": "4.6.0",
    "classnames": "2.3.1",
    "connected-react-router": "6.9.1",
    "crypto-browserify": "3.12.0",
    "dayjs": "1.10.7",
    "dotenv": "9.0.2",
    "history": "4.10.1",
    "lodash": "4.17.21",
    "markdown-to-jsx": "6.11.4",
    "moize": "5.4.7",
    "prop-types": "15.7.2",
    "query-string": "7.0.1",
    "react": "17.0.2",
    "react-day-picker": "7.4.10",
    "react-dom": "17.0.2",
    "react-google-login": "4.0.1",
    "react-popper": "1.3.11",
    "react-redux": "7.2.5",
    "react-router-dom": "5.3.0",
    "react-select": "3.2.0",
    "react-table-6": "6.11.0",
    "react-tippy": "1.4.0",
    "react-toastify": "5.5.0",
    "reactstrap": "8.10.0",
    "recompose": "0.30.0",
    "redux": "4.1.2",
    "redux-thunk": "2.4.0",
    "reselect": "4.0.0",
    "socket.io-client": "2.4.0",
    "stream-browserify": "3.0.0",
    "styled-components": "5.3.3",
    "universal-cookie": "3.1.0"
  },
  "devDependencies": {
    "git-branch": "2.0.1"
  },
  "files": [
    "build"
  ],
  "homepage": "https://github.com/voiceflow/creator-app#readme",
  "license": "UNLICENSED",
  "main": "build/index.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "scripts": {
    "build": "wp --prod",
    "build:dev": "wp",
    "build:e2e": "wp --instrument",
    "connect:cli": "vfcli mesh connect admin-ui -c \"/bin/bash\"",
    "e2e:check-deps": "until [[ $(curl -I --silent -o /dev/null -w %{http_code} https://localhost:8003/health) =~ 2[0-9][0-9]  ]] ;do sleep 5;done",
    "gen-certs:e2e": "scripts/generate_e2e_certs.sh",
    "kill:e2e": "kill -9 $(lsof -t -i tcp:3003) || true",
    "lint": "concurrently -c yellow,blue,magenta \"yarn:lint:js\" \"yarn:lint:css\" \"yarn:lint:dockerfiles\"",
    "lint:css": "stylelint src/**/*.css",
    "lint:dockerfiles": "hadolint --ignore DL3018 ./Dockerfile",
    "lint:fix": "yarn lint:js --fix",
    "lint:js": "eslint \"**/*.{js,ts}\"",
    "lint:quiet": "concurrently -c yellow,blue \"yarn:lint:js --rule 'prettier/prettier: off' --quiet\" \"yarn:lint:css --quiet\" --color",
    "lint:report": "yarn lint:js --format json -o sonar/report.json && yarn lint:css --formatter json --output-file sonar/report_css.json",
    "local": "vfcli mesh connect admin-ui",
    "local:e2e": "yarn kill:e2e && E2E=true yarn start",
    "start": "vf-dev-server --action serve",
    "start:e2e": "scripts/start_e2e.sh",
    "start:hidden": "yarn start --no-open",
    "start:meshed": "yarn start:proxy && IS_MESHED=true yarn start --typecheck",
    "start:proxy": "scripts/generate_certs.sh && docker compose up -d proxy",
    "test": "exit 0",
    "test:dependencies": "depcheck",
    "test:integration": "exit 0",
    "test:unit": "exit 0",
    "types": "tsc --project tsconfig.build.json --noEmit --skipLibCheck"
  }
}
