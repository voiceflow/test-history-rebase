{
  "ignorePatterns": [
    "/build",
    "/sonar",
    "/.jest_cache",
    "/.nyc_output",
    "/jest_coverage",
    "/nyc_coverage_unit"
  ],
  "specials": [
    "bin",
    "istanbul",
    "jest",
    "babel"
  ],
  "ignores": [
    "@voiceflow/dependency-cruiser-config",
    "buffer",
    "@babel/core",
    "@logux/state",
    "@types/*",
    "postcss*",
    "identity-obj-proxy",
    "ignore-styles",
    "mock-local-storage",
    "tslib",
    "ts-node",
    "node-noop",
    "levenary",
    "estree",
    "mocha",
    "mocha-suite",
    "mock-require",
    "sinon",
    "sinon-chai",
    "chai",
    "chai-as-promised",
    "react-hot-loader",
    "stream-browserify"
  ]
}
