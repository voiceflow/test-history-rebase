{
  "specials": ["bin", "eslint", "istanbul", "ttypescript", "webpack", "jest", "babel"],
  "ignores": [
    "@svgr/webpack",
    "@hot-loader/react-dom",
    "@types/*",
    "@voiceflow/eslint-config",
    "postcss*",
    "eslint-import-resolver-typescript",
    "babel-*",
    "@babel/preset-es2015",
    "@babel/preset-typescript",
    "@babel/helper-simple-access",
    "babel/preset-react",
    "css-loader",
    "postcss-loader",
    "file-loader",
    "style-loader",
    "identity-obj-proxy",
    "ignore-styles",
    "mock-local-storage",
    "istanbul-instrumenter-loader",
    "tslib",
    "ts-node",
    "ts-loader",
    "node-noop",
    "levenary",
    "estree",
    "mocha",
    "mocha-suite",
    "sinon",
    "sinon-chai",
    "chai",
    "chai-as-promised",
    "_storybook"
  ]
}
