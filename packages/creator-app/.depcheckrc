{
  "ignorePatterns": [
    "/build",
    "/sonar",
    "/coverage"
  ],
  "specials": [
    "bin",
    "istanbul",
    "babel"
  ],
  "ignores": [
    "@voiceflow/vite-config",
    "@voiceflow/dependency-cruiser-config",
    "buffer",
    "chai",
    "@logux/state",
    "@types/*",
    "postcss*",
    "identity-obj-proxy",
    "ignore-styles",
    "mock-local-storage",
    "tslib",
    "node-noop",
    "jsdom-global",
    "levenary",
    "estree",
    "vitest",
    "react-hot-loader",
    "null-loader",
    "stream-browserify"
  ]
}
