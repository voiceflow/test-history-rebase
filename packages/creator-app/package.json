  "scripts": {
    "build": "yarn build:types && NODE_ENV=production vite build && yarn build:copy-prototype",
    "build:copy-prototype": "cp build/index.html build/prototype.html",
    "build:dev": "SOURCE_MAPS=true vite build && yarn build:copy-prototype",
    "build:e2e": "VF_APP_BUILD_ENV=e2e VF_APP_E2E=true vite build && yarn build:copy-prototype",
    "build:types": "tsc --project tsconfig.build.json --skipLibCheck",
    "build:webpack": "wp --prod",
    "clean:build": "rm -rf build",
    "connect:cli": "vfcli mesh connect creator-app -c \"/bin/bash\"",
    "cypress": "NODE_ENV=test cypress open",
    "cypress:ci": "if npx wait-on --timeout 6000 $CYPRESS_API_URL; then yarn cypress:ci-sorry-cypress; else yarn cypress:ci-cypress; fi",
    "cypress:ci-cypress": "NODE_ENV=test cypress run --env CI=true --parallel --record --group=\"ci-run\" --ci-build-id=\"$CIRCLE_WORKFLOW_ID\" --config defaultCommandTimeout=20000",
    "cypress:ci-sorry-cypress": "NODE_ENV=test cy2 run --env CI=true --parallel --record --group=\"ci-run\" --ci-build-id=\"$CIRCLE_WORKFLOW_ID\" --config defaultCommandTimeout=20000",
    "cypress:install": "cypress install && cypress verify",
    "cypress:run": "NODE_ENV=test cypress run",
    "e2e": "yarn kill:e2e && concurrently -c yellow,blue \"VF_APP_E2E=true VF_APP_BUILD_ENV=e2e vite build --watch\" \"VF_APP_E2E=true vite preview --port 3002\"",
    "e2e:check-deps": "npx wait-on https://localhost:8003/health && npx wait-on https://localhost:8011/health && npx wait-on https://localhost:8005/health && npx wait-on https://localhost:8006/health && npx wait-on https://localhost:8001/health && npx wait-on https://localhost:8008/health",
    "e2e:check-deps-ci": "npx wait-on https://creator-api.test.e2e:8003/health && npx wait-on https://general-runtime.test.e2e:8005/health && npx wait-on https://alexa-service.test.e2e:8001/health && npx wait-on https://general-service.test.e2e:8006/health && npx wait-on https://google-service.test.e2e:8008/health",
    "gen-certs:e2e": "scripts/generate_e2e_certs.sh",
    "kill:e2e": "npx kill-port 3002 || true",
    "kill:process": "yarn kill:e2e",
    "lint": "concurrently -c yellow,blue,magenta,purple \"yarn:lint:js\" \"yarn:lint:css\" \"yarn:lint:dockerfiles\" \"yarn:lint:dependencies\"",
    "lint:css": "stylelint src/**/*.css",
    "lint:dependencies:ci": "concurrently -c yellow,blue \"yarn:lint:deps:circular --no-spinner\" \"yarn:lint:deps:dead --no-spinner\"",
    "lint:deps:circular": "madge --circular -x NestedMenu/MenuOptions/index.jsx ./src/index.tsx",
    "lint:deps:dead": "madge --orphans ./src/index.tsx",
    "lint:dockerfiles": "hadolint --ignore DL3018 ./Dockerfile",
    "lint:fix": "yarn lint:js --fix --rule 'react-hooks/exhaustive-deps: off'",
    "lint:js": "eslint \"src/**/*.{js,ts,jsx,tsx}\" --cache --cache-strategy content",
    "lint:quiet": "concurrently -c yellow,blue \"yarn:lint:js --rule 'prettier/prettier: off' --quiet\" \"yarn:lint:css --quiet\" --color",
    "lint:report": "yarn lint:js --format json -o sonar/report.json && yarn lint:css --formatter json --output-file sonar/report_css.json",
    "local": "yarn kill:process && vfcli mesh connect creator-app",
    "local:e2e": "yarn kill:e2e && VF_APP_E2E=true VF_APP_BUILD_ENV=e2e vite",
    "mesh:post": "exit 0",
    "mesh:pre": "exit 0",
    "start": "NODE_ENV=development vite",
    "start:e2e": "scripts/start_e2e.sh",
    "start:hidden": "yarn start --no-open",
    "start:meshed": "scripts/generate_certs.sh && yarn start",
    "start:proxy": "scripts/generate_certs.sh && docker compose up -d proxy",
    "start:webpack": "vf-dev-server --action serve",
    "tdd:integration": "yarn test:integration --watchAll=true",
    "tdd:unit": "NODE_ENV=test ts-mocha --project tsconfig.test.json --paths --watch --config config/test/unit/mocharc.yml",
    "test": "yarn test:unit && yarn test:integration",
    "test:dependencies": "depcheck",
    "test:integration": "NODE_ENV=test jest --coverage --config config/test/integration/jest.config.js",
    "test:unit": "NODE_ENV=test nyc --report-dir=nyc_coverage_unit ts-mocha --project tsconfig.test.json --paths --config config/test/unit/mocharc.yml",
    "types": "tsc --project tsconfig.build.json --noEmit --skipLibCheck"
  }
}
