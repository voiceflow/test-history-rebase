{
  "extends": "@voiceflow/tsconfig/web.json",
  "compilerOptions": {
    "allowJs": true,
    "isolatedModules": false,
    "lib": [
      "es2019",
      "dom",
      "es2020.string",
      "dom.iterable"
    ],
    "baseUrl": "..",
    "outDir": "build",
    "paths": {
      "@ui/*": [
        "ui/src/*"
      ],
      "@ui": [
        "ui/src"
      ],
      "@voiceflow/ui": [
        "ui/src"
      ],
      "@realtime-sdk/*": [
        "realtime-sdk/src/*"
      ],
      "@realtime-sdk": [
        "realtime-sdk/src"
      ],
      "@voiceflow/realtime-sdk": [
        "realtime-sdk/src"
      ],
      "@ml-sdk/*": [
        "ml-sdk/src/*"
      ],
      "@ml-sdk": [
        "ml-sdk/src"
      ],
      "@voiceflow/ml-sdk": [
        "ml-sdk/src"
      ],
      "@/*": [
        "creator-app/src/*"
      ]
    },
    "types": [
      "gapi",
      "gapi.auth2",
      "resize-observer-browser",
      "webpack-env",
      "dayjs/plugin/relativeTime",
      "dayjs/plugin/minMax"
    ]
  },
  "exclude": [
    "node_modules/**/*",
    "build/**/*",
    "config/webpack/**/*"
  ]
}
