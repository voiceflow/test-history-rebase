{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "importHelpers": true,
    "baseUrl": ".",
    "paths": {
      "@voiceflow/ui": [
        "../../node_modules/@voiceflow/ui"
      ],
      "@voiceflow/realtime-sdk": [
        "../../node_modules/@voiceflow/realtime-sdk"
      ],
      "@voiceflow/ml-sdk": [
        "../../node_modules/@voiceflow/ml-sdk"
      ],
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "jest",
      "gapi",
      "gapi.auth2",
      "resize-observer-browser",
      "dayjs/plugin/relativeTime",
      "dayjs/plugin/minMax"
    ]
  }
}
