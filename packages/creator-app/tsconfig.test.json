{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "baseUrl": ".",
    "rootDir": "src",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "importHelpers": true,
    "types": [
      "jest",
      "gapi",
      "gapi.auth2",
      "resize-observer-browser",
      "webpack-env",
      "dayjs/plugin/relativeTime",
      "dayjs/plugin/minMax"
    ]
  }
