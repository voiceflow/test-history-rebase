{
  "name": "@voiceflow/ml-gateway",
  "version": "1.7.1",
  "dependencies": {
    "@logux/server": "0.10.8",
    "@voiceflow/backend-utils": "4.3.1",
    "@voiceflow/logger": "1.6.1",
    "@voiceflow/ml-sdk": "^1.7.1",
    "@voiceflow/socket-utils": "^1.10.0",
    "axios": "0.24.0",
    "core-js": "3.20.3",
    "dotenv": "14.3.2",
    "express-validator": "6.14.0",
    "regenerator-runtime": "0.13.9"
  },
  "devDependencies": {
    "@types/ioredis": "4.28.7"
  },
  "engines": {
    "node": ">=16"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "analyze:dependencies": "depcruise --exclude src/models.ts --validate -- src",
    "build": "yarn clean && ttsc --project tsconfig.build.json",
    "clean": "rimraf build",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 nodemon src/index.ts",
    "e2e": "yarn kill:e2e && NODE_ENV=e2e NODE_TLS_REJECT_UNAUTHORIZED=0 yarn start:base",
    "e2e:check-deps": "npx wait-on https://localhost:8003/health ",
    "e2e:check-deps-ci": "npx wait-on https://creator-api.test.e2e:8003/health",
    "e2e:ci": "./scripts/run_e2e_ci.sh",
    "gen-certs:e2e": "scripts/generate_e2e_certs.sh",
    "kill:e2e": "npx kill-port 8015 || true",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:dockerfiles": "hadolint --ignore DL3018 ./Dockerfile",
    "lint:fix": "yarn lint --fix",
    "lint:quiet": "yarn lint --quiet",
    "lint:report": "yarn lint --format json -o sonar/report.json",
    "local": "vfcli mesh connect ml-gateway",
    "local:e2e": "yarn kill:e2e && NODE_ENV=e2e NODE_TLS_REJECT_UNAUTHORIZED=0 yarn dev",
    "mesh:post": "exit 0",
    "mesh:pre": "exit 0",
    "start": "PORT=8015 CREATOR_API_ENDPOINT=https:// NODE_ENV=production yarn start:base",
    "start:base": "node --experimental-specifier-resolution=node --max-old-space-size=8192 build/index.js",
    "start:meshed": "NODE_ENV=local IS_MESHED=true yarn dev",
    "test": "yarn test:unit",
    "test:dependencies": "depcheck",
    "test:integration": "exit 0",
    "test:unit": "NODE_ENV=test nyc --report-dir=nyc_coverage_unit ts-mocha --project tsconfig.test.json --paths --config config/test/unit/mocharc.yml",
    "types": "tsc --project tsconfig.build.json --noEmit --skipLibCheck"
  },
  "type": "module"
}
