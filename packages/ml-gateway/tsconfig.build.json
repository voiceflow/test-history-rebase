{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "build",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "plugins": [
      {
        "transform": "@zerollup/ts-transform-paths"
      }
    ]
  },
  "include": [
    "src/**/*"
  ]
}
