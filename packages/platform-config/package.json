{
  "name": "@voiceflow/platform-config",
  "version": "1.15.3",
  "author": "Voiceflow",
  "bugs": {
    "url": "https://github.com/voiceflow/creator-app/issues"
  },
  "dependencies": {
    "@voiceflow/alexa-types": "2.12.22",
    "@voiceflow/api-sdk": "3.22.7",
    "@voiceflow/base-types": "2.77.1",
    "@voiceflow/chat-types": "2.13.15",
    "@voiceflow/common": "8.1.5",
    "@voiceflow/google-dfes-types": "2.14.25",
    "@voiceflow/google-types": "2.18.18",
    "@voiceflow/slate-serializer": "1.3.0",
    "@voiceflow/ui": "^1.212.1",
    "@voiceflow/voice-types": "2.8.26",
    "@voiceflow/voiceflow-types": "3.22.6",
    "bidirectional-adapter": "1.2.0",
    "normal-store": "1.3.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "styled-components": "^5.3.0",
    "utility-types": "^3.10.0"
  },
  "devDependencies": {
    "@testing-library/react": "^12.1.5",
    "jest-styled-components": "7.1.1",
    "jsdom": "^20.0.3",
    "tslib": "2.4.1"
  },
  "files": [
    "build"
  ],
  "homepage": "https://github.com/voiceflow/creator-app#readme",
  "license": "UNLICENSED",
  "main": "build/common/index.js",
  "module": "build/module/index.js",
  "peerDependencies": {
    "react-router": "5.2.1",
    "react-router-dom": "5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "scripts": {
    "analyze:dependencies": "depcruise --validate -- src",
    "build": "yarn clean && concurrently -c yellow,blue 'yarn:build:cjs' 'yarn:build:esm'",
    "build:cjs": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:esm": "tsc --project tsconfig.module.json && tsc-alias -p tsconfig.module.json",
    "clean": "yarn clean:build",
    "clean:build": "rimraf build",
    "lint": "concurrently -c yellow,blue \"yarn:lint:js\"",
    "lint:dockerfiles": "exit 0",
    "lint:fix": "yarn lint:js --fix",
    "lint:js": "eslint \"**/*.{js,ts}\"",
    "lint:quiet": "concurrently -c yellow,blue \"yarn:lint:js --rule 'prettier/prettier: off' --quiet\" --color",
    "lint:report": "yarn lint:js --format json -o sonar/report.json",
    "test": "vitest run --coverage",
    "test:dependencies": "depcheck",
    "test:integration": "exit 0",
    "test:unit": "REPORTS_DIRECTORY=coverage/unit vitest run .unit --silent --coverage",
    "types": "tsc --project tsconfig.build.json --noEmit --skipLibCheck",
    "watch:esm": "yarn build:esm && (concurrently \"tsc --watch --project tsconfig.module.json\" \"tsc-alias -w -p tsconfig.module.json\")"
  }
}
