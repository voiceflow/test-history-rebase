{
  "name": "@voiceflow/realtime-sdk",
  "version": "1.151.1",
  "author": "Voiceflow",
  "bugs": {
    "url": "https://github.com/voiceflow/creator-app/issues"
  },
  "dependencies": {
    "@voiceflow/alexa-types": "2.10.24",
    "@voiceflow/base-types": "2.61.0",
    "@voiceflow/chat-types": "2.12.1",
    "@voiceflow/common": "8.1.4",
    "@voiceflow/google-dfes-types": "2.12.25",
    "@voiceflow/google-types": "2.15.20",
    "@voiceflow/internal": "2.3.1",
    "@voiceflow/voice-types": "2.8.1",
    "@voiceflow/voiceflow-types": "3.20.1",
    "bidirectional-adapter": "^1.0.0",
    "dayjs": "1.10.7",
    "is-var-name": "^2.0.0",
    "lodash": "^4.17.20",
    "moize": "^5.4.7",
    "normal-store": "1.3.0",
    "slate": "0.73.0",
    "typescript-fsa": "^3.0.0",
    "utility-types": "^3.10.0"
  },
  "devDependencies": {
    "@types/faker": "5.5.9",
    "@voiceflow/api-sdk": "3.20.1",
    "cooky-cutter": "1.5.4",
    "draft-js": "0.11.7",
    "faker": "5.5.3",
    "polished": "3.7.2"
  },
  "files": [
    "build"
  ],
  "homepage": "https://github.com/voiceflow/creator-app#readme",
  "license": "UNLICENSED",
  "main": "build/common/index.js",
  "module": "build/module/index.js",
  "peerDependencies": {
    "@voiceflow/api-sdk": "3.20.1",
    "draft-js": "^0.11.2",
    "polished": "^3.6.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "scripts": {
    "analyze:dependencies": "depcruise --validate -- src",
    "build": "yarn clean && concurrently -c yellow,blue 'yarn:build:cjs' 'yarn:build:esm'",
    "build:cjs": "ttsc --project tsconfig.build.json",
    "build:esm": "ttsc --project tsconfig.module.json",
    "build:watch": "yarn clean && concurrently -c yellow,blue 'yarn:build:cjs --watch' 'yarn:build:esm --watch'",
    "clean": "rimraf build",
    "dev": "yarn clean && concurrently -c yellow,blue 'yarn:build:cjs --watch' 'yarn:build:esm --watch'",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:dockerfiles": "exit 0",
    "lint:fix": "yarn lint --fix",
    "lint:quiet": "yarn lint --quiet",
    "lint:report": "yarn lint --format json -o sonar/report.json",
    "test": "nyc ts-mocha --project tsconfig.test.json --paths --config config/test/mocharc.yml",
    "test:dependencies": "depcheck",
    "test:integration": "yarn test",
    "test:unit": "yarn test",
    "types": "tsc --project tsconfig.build.json --noEmit --skipLibCheck"
  }
}
