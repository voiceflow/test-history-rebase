    "@voiceflow/common": "6.5.1",
    "@voiceflow/general-types": "1.55.2",
    "@voiceflow/google-types": "1.34.8",
    "@voiceflow/internal": "^1.6.0",
    "@voiceflow/voice-types": "^1.1.0",
    "bson-objectid": "^1.3.1",
    "cuid": "^2.1.8",
    "is-var-name": "^2.0.0",
    "lodash": "^4.17.20",
    "moize": "^5.4.7",
    "moment": "^2.29.1",
    "typescript-fsa": "^3.0.0"
  },
  "devDependencies": {
    "@voiceflow/api-sdk": "^1.34.2",
    "draft-js": "^0.11.2",
    "polished": "^3.6.5",
    "slate": "0.63.0"
  },
  "files": [
    "build"
  ],
  "homepage": "https://github.com/voiceflow/creator-app#readme",
  "license": "UNLICENSED",
  "main": "build/common/index.js",
  "module": "build/module/index.js",
  "peerDependencies": {
    "@voiceflow/api-sdk": "^1.31.10",
    "draft-js": "^0.11.2",
    "polished": "^3.6.5",
    "slate": "0.63.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "scripts": {
    "build": "yarn clean && concurrently -c yellow,blue 'yarn:build:cjs' 'yarn:build:esm'",
    "build:cjs": "ttsc --project tsconfig.build.json",
    "build:esm": "ttsc --project tsconfig.module.json",
    "clean": "rimraf build",
    "dev": "yarn clean && concurrently -c yellow,blue 'yarn:build:cjs --watch' 'yarn:build:esm --watch'",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:dockerfiles": "exit 0",
    "lint:fix": "yarn lint --fix",
    "lint:quiet": "yarn lint --quiet",
    "lint:report": "yarn lint --format json -o sonar/report.json",
    "test": "exit 0",
    "test:dependencies": "depcheck",
    "test:integration": "exit 0",
    "test:unit": "exit 0"
  }
}
