  },
  "dependencies": {
    "@voiceflow/alexa-types": "1.52.38",
    "@voiceflow/base-types": "1.6.3",
    "@voiceflow/chat-types": "1.4.14",
    "@voiceflow/common": "6.5.1",
    "@voiceflow/general-types": "1.55.17",
    "@voiceflow/google-types": "1.34.24",
    "@voiceflow/internal": "^1.6.1",
    "@voiceflow/voice-types": "1.4.14",
    "bson-objectid": "^1.3.1",
    "cuid": "^2.1.8",
    "dayjs": "^1.10.7",
    "is-var-name": "^2.0.0",
    "lodash": "^4.17.20",
    "moize": "^5.4.7",
    "typescript-fsa": "^3.0.0",
    "utility-types": "^3.10.0"
  },
  "devDependencies": {
    "@types/chai": "^4.2.21",
    "@types/faker": "^5.5.8",
    "@types/sinon": "^10.0.2",
    "@voiceflow/api-sdk": "^1.37.1",
    "chai": "^4.3.4",
    "cooky-cutter": "^1.5.4",
    "draft-js": "^0.11.2",
    "faker": "^5.5.3",
    "mocha": "^9.1.1",
    "polished": "^3.6.5",
    "sinon": "^11.1.2",
    "slate": "0.63.0",
    "ts-mocha": "^8.0.0",
    "tsconfig-paths": "^3.11.0"
  },
  "files": [
    "build"
  ],
  "homepage": "https://github.com/voiceflow/creator-app#readme",
  "license": "UNLICENSED",
  "main": "build/common/index.js",
  "module": "build/module/index.js",
  "peerDependencies": {
    "@voiceflow/api-sdk": "^1.37.1",
    "draft-js": "^0.11.2",
    "polished": "^3.6.5",
    "slate": "0.63.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "scripts": {
    "build": "yarn clean && concurrently -c yellow,blue 'yarn:build:cjs' 'yarn:build:esm'",
    "build:cjs": "ttsc --project tsconfig.build.json",
    "build:esm": "ttsc --project tsconfig.module.json",
    "clean": "rimraf build",
    "dev": "yarn clean && concurrently -c yellow,blue 'yarn:build:cjs --watch' 'yarn:build:esm --watch'",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:dockerfiles": "exit 0",
    "lint:fix": "yarn lint --fix",
    "lint:quiet": "yarn lint --quiet",
    "lint:report": "yarn lint --format json -o sonar/report.json",
    "test": "ts-mocha --paths --config ./config/tests/mocharc.yml 'tests/**/*.{unit,it}.ts'",
    "test:dependencies": "depcheck",
    "test:integration": "yarn test",
    "test:unit": "yarn test"
  }
}
