{
  "extends": "@voiceflow/tsconfig",
  "compilerOptions": {
    "lib": [
      "es2017",
      "es2019.array"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/tests/*": ["./tests/__support__/*"],
    },
    "baseUrl": ".",
    "typeRoots": [
      "node_modules/@types", "./typings"
    ],
    "types": [
      "mocha",
      "chai",
      "node",
    ],
  },
  "compileOnSave": false,
  "exclude": [
    "node_modules/**",
    "build/**"
  ],
}
