{
  "extends": "@voiceflow/tsconfig",
  "compilerOptions": {
    "skipLibCheck": true,
    "baseUrl": "..",
    "paths": {
      "@voiceflow/socket-utils": [
        "socket-utils/src"
      ],
      // only used to fix intra-monorepo resolution
      "@socket-utils/*": [
        "socket-utils/src/*"
      ],
      "@realtime-sdk/*": [
        "realtime-sdk/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules/**/*",
    "build/**/*"
  ]
}
