{
  "name": "@voiceflow/realtime",
  "version": "1.21.0",
  "dependencies": {
    "@logux/actions": "0.2.1",
    "@logux/core": "0.7.2",
    "@logux/server": "0.10.6",
    "@voiceflow/alexa-types": "2.0.5",
    "@voiceflow/api-sdk": "3.1.0",
    "@voiceflow/backend-utils": "4.1.0",
    "@voiceflow/base-types": "^2.1.2",
    "@voiceflow/common": "7.6.1",
    "@voiceflow/general-types": "3.0.3",
    "@voiceflow/google-dfes-types": "2.1.2",
    "@voiceflow/google-types": "2.0.3",
    "@voiceflow/internal": "2.2.0",
    "@voiceflow/logger": "1.6.0",
    "@voiceflow/realtime-sdk": "^1.38.0",
    "axios": "0.21.2",
    "bidirectional-adapter": "^1.0.0",
    "cbor": "8.0.2",
    "core-js": "3.18.0",
    "dotenv": "9.0.2",
    "express-validator": "6.13.0",
    "ioredis": "4.28.0",
    "lodash": "4.17.21",
    "moize": "6.0.3",
    "path-to-regexp": "6.2.0",
    "polished": "3.7.2",
    "regenerator-runtime": "0.13.9",
    "typescript-fsa": "3.0.0",
    "utility-types": "3.10.0"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "1.0.1",
    "@types/deep-equal-in-any-order": "1.0.1",
    "@types/ioredis": "4.27.7",
    "deep-equal-in-any-order": "1.1.13",
    "node-dev": "7.0.0",
    "nodemon": "2.0.13"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "yarn clean && ttsc --project tsconfig.build.json",
    "clean": "rimraf build",
    "dev": "yarn build --watch",
    "e2e": "yarn kill:e2e && NODE_ENV=e2e NODE_TLS_REJECT_UNAUTHORIZED=0 nodemon src/index.ts",
    "e2e:node-dev": "yarn kill:e2e && NODE_ENV=e2e node-dev -r esm  src/index.ts",
    "gen-certs:e2e": "scripts/generate_e2e_certs.sh",
    "kill:e2e": "kill -9 $(lsof -t -i tcp:8013) || true",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:dockerfiles": "hadolint --ignore DL3018 ./Dockerfile",
    "lint:fix": "yarn lint --fix",
    "lint:quiet": "yarn lint --quiet",
    "lint:report": "yarn lint --format json -o sonar/report.json",
    "local": "vfcli mesh connect realtime",
    "start": "PORT=8013 CREATOR_API_ENDPOINT=https:// NODE_ENV=production node --experimental-specifier-resolution=node --max-old-space-size=8192 build/index.js",
    "start:e2e": "NODE_ENV=e2e node --experimental-specifier-resolution=node --max-old-space-size=8192 build/index.js",
    "start:meshed": "NODE_ENV=local IS_MESHED=true NODE_TLS_REJECT_UNAUTHORIZED=0 nodemon src/index.ts",
    "test": "yarn test:unit",
    "test:dependencies": "depcheck",
    "test:integration": "exit 0",
    "test:unit": "NODE_ENV=test nyc --report-dir=nyc_coverage_unit ts-mocha --project tsconfig.test.json --paths --config config/test/unit/mocharc.yml"
  },
  "type": "module"
}
