{
  "name": "@voiceflow/realtime",
  "version": "1.5.0",
  "dependencies": {
    "@logux/actions": "^0.2.0",
    "@logux/core": "^0.7.0",
    "@logux/server": "^0.10.0",
    "@voiceflow/common": "^6.5.1",
    "@voiceflow/logger": "^1.5.6",
    "@voiceflow/realtime-sdk": "^1.4.0",
    "axios": "^0.21.1",
    "core-js": "^3.12.1",
    "ioredis": "^4.27.6",
    "path-to-regexp": "^6.2.0",
    "regenerator-runtime": "^0.13.7",
    "typescript-fsa": "^3.0.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.26.5",
    "node-dev": "^7.0.0",
    "nodemon": "^2.0.7"
  },
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "yarn clean && ttsc --project tsconfig.build.json",
    "clean": "rimraf build",
    "dev": "yarn build --watch",
    "e2e": "yarn kill:e2e && NODE_ENV=e2e NODE_TLS_REJECT_UNAUTHORIZED=0 nodemon src/index.ts",
    "e2e:node-dev": "yarn kill:e2e && NODE_ENV=e2e node-dev -r esm  src/index.ts",
    "gen-certs:e2e": "scripts/generate_e2e_certs.sh",
    "kill:e2e": "kill -9 $(lsof -t -i tcp:8013) || true",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:fix": "yarn lint --fix",
    "lint:quiet": "yarn lint --quiet",
    "lint:report": "yarn lint --format json -o sonar/report.json",
    "start": "PORT=8013 CREATOR_API_ENDPOINT=https:// NODE_ENV=production node --experimental-specifier-resolution=node --max-old-space-size=8192 build/index.js",
    "start:e2e": "NODE_ENV=e2e node --experimental-specifier-resolution=node --max-old-space-size=8192 build/index.js",
    "test": "exit 0",
    "test:dependencies": "depcheck",
    "test:integration": "exit 0",
    "test:unit": "exit 0"
  }
}
