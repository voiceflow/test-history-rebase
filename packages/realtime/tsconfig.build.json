{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "build",
    "declaration": true,
    "plugins": [
      {
        "transform": "@zerollup/ts-transform-paths"
      }
    ],
    "baseUrl": ".",
    "rootDir": "src",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "exclude": [
    "node_modules/**",
    "build/**",
    "test/**"
  ]
}
