{
  "extends": "@voiceflow/tsconfig",
  "ts-node": {
    "compiler": "ttypescript"
  },
  "compilerOptions": {
    "target": "ES2017",
    "module": "esnext",
    "baseUrl": "..",
    "rootDirs": ["src", "../realtime-sdk/src"],
    "typeRoots": ["../../node_modules/@types"],
    "paths": {
      "@voiceflow/realtime-sdk": ["realtime-sdk/src"],
      "@/*": ["realtime/src/*"]
    }
  },
  "compileOnSave": false,
  "exclude": ["node_modules/**", "build/**"]
}
