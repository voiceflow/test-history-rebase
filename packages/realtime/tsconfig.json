{
  "extends": "@voiceflow/tsconfig",
  "ts-node": {
    "compiler": "ttypescript"
  },
  "compilerOptions": {
    "module": "esnext",
    "skipLibCheck": true,
    "baseUrl": "..",
    "paths": {
      "@voiceflow/realtime-sdk": [
        "realtime-sdk/src"
      ],
      "@voiceflow/socket-utils": [
        "socket-utils/src"
      ],
      "@/*": [
        "realtime/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules/**/*",
    "build/**/*",
    "test/**/*.d.ts"
  ]
}
