{
  "ignorePatterns": [
    "/build"
  ],
  "specials": [
    "bin",
    "istanbul",
    "ttypescript"
  ],
  "ignores": [
    "@ui/*",
    "@types/*",
    "ts-jest",
    "tslib",
    "chai",
    "chai-as-promised",
    "mocha-suite",
    "sinon",
    "sinon-chai",
    "jsdom-global",
    "ignore-styles",
    "regenerator-runtime"
  ]
}
