{
  "name": "@voiceflow/ui",
  "version": "1.8.0",
  "author": "Voiceflow",
  "bugs": {
    "url": "https://github.com/voiceflow/creator-app/issues"
  },
  "dependencies": {
    "@seznam/compose-react-refs": "^1.0.6",
    "bowser": "^2.11.0",
    "classnames": "^2.3.1",
    "cross-fetch": "^3.0.6",
    "csstype": "^3.0.8",
    "cuid": "^2.1.8",
    "lodash": "^4.17.21",
    "loglevel": "^1.7.1",
    "moize": "^5.4.7",
    "object-hash": "^2.1.1",
    "prop-types": "^15.7.2",
    "query-string": "^7.0.0",
    "react": "^16.13.1",
    "react-color": "^2.19.3",
    "react-custom-scrollbars": "^4.2.1",
    "react-dismissable-layers": "^0.1.1",
    "react-dom": "^16.13.1",
    "react-input-autosize": "^2.2.2",
    "react-popper": "^1.3.3",
    "react-router-dom": "^5.2.0",
    "react-tippy": "1.4.0",
    "react-toastify": "^5.5.0",
    "react-toggle": "^4.1.2",
    "react-transition-group": "^4.4.2",
    "recompose": "^0.30.0",
    "redux": "^4.0.5",
    "styled-components": "^5.3.0",
    "styled-system": "^5.1.5",
    "universal-cookie": "^3.0.4",
    "utility-types": "^3.10.0"
  },
  "devDependencies": {
    "@svgr/cli": "^5.5.0",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^12.0.0",
    "@types/jest": "^26.0.23",
    "@types/node": "^16.4.4",
    "@types/react-input-autosize": "^2.2.1",
    "jest": "^26.6.3",
    "jest-styled-components": "^7.0.4",
    "ts-jest": "26.5.6",
    "tslib": "2.3.0"
  },
  "files": [
    "build"
  ],
  "homepage": "https://github.com/voiceflow/creator-app#readme",
  "license": "UNLICENSED",
  "main": "build/common/index.js",
  "module": "build/module/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "scripts": {
    "build": "yarn clean && yarn build:svg && concurrently -c yellow,blue 'yarn:build:cjs' 'yarn:build:esm'",
    "build:cjs": "ttsc --project tsconfig.build.json && ./scripts/copy_assets.sh common",
    "build:esm": "ttsc --project tsconfig.module.json && ./scripts/copy_assets.sh module",
    "build:svg": "svgr --out-dir src/svgs src/svgs && yarn clean:svg-index",
    "clean": "yarn clean:build && yarn clean:svg",
    "clean:build": "rimraf build",
    "clean:svg": "rimraf \"src/svgs/**/*.svg.jsx\"",
    "clean:svg-index": "rimraf \"src/svgs/**/index.svg.jsx\"",
    "lint": "concurrently -c yellow,blue \"yarn:lint:js\" \"yarn:lint:css\"",
    "lint:css": "stylelint src/**/*.css",
    "lint:dockerfiles": "exit 0",
    "lint:fix": "yarn lint:js --fix",
    "lint:js": "eslint \"**/*.{js,ts}\"",
    "lint:quiet": "concurrently -c yellow,blue \"yarn:lint:js --rule 'prettier/prettier: off' --quiet\" \"yarn:lint:css --quiet\" --color",
    "lint:report": "yarn lint:js --format json -o sonar/report.json && yarn lint:css --formatter json --output-file sonar/report_css.json",
    "test": "exit 0",
    "test:dependencies": "depcheck",
    "test:integration": "NODE_ENV=test jest --coverage --config config/test/integration/jest.config.js",
    "test:unit": "NODE_ENV=test nyc --report-dir=nyc_coverage_unit ts-mocha --project tsconfig.test.json --paths --config config/test/unit/mocharc.yml",
    "watch:esm": "yarn build:esm && ttsc --watch --project tsconfig.module.json"
  }
}
