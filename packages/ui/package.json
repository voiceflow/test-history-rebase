  "files": [
    "build"
  ],
  "homepage": "https://github.com/voiceflow/creator-app#readme",
  "license": "UNLICENSED",
  "main": "build/common/index.js",
  "module": "build/module/index.js",
  "peerDependencies": {
    "react-router": "5.2.1",
    "react-router-dom": "5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voiceflow/creator-app.git"
  },
  "scripts": {
    "analyze:dependencies": "depcruise --exclude 'src/(svgs|components/NestedMenu/Menu)' --validate -- src",
    "build": "yarn clean && yarn build:svg && concurrently -c yellow,blue 'yarn:build:cjs' 'yarn:build:esm'",
    "build:cjs": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json && ./scripts/copy_assets.sh common",
    "build:esm": "tsc --project tsconfig.module.json && tsc-alias -p tsconfig.module.json && ./scripts/copy_assets.sh module",
    "build:svg": "svgr --out-dir src/svgs src/svgs && yarn clean:svg-index",
    "clean": "yarn clean:build && yarn clean:svg",
    "clean:build": "rimraf build",
    "clean:svg": "rimraf \"src/svgs/**/*.svg.jsx\"",
    "clean:svg-index": "rimraf \"src/svgs/**/index.svg.jsx\"",
    "lint": "concurrently -c yellow,blue \"yarn:lint:js\" \"yarn:lint:css\"",
    "lint:css": "stylelint src/**/*.css",
    "lint:dockerfiles": "exit 0",
    "lint:fix": "yarn lint:js --fix",
    "lint:js": "eslint \"**/*.{js,ts}\"",
    "lint:quiet": "concurrently -c yellow,blue \"yarn:lint:js --rule 'prettier/prettier: off' --quiet\" \"yarn:lint:css --quiet\" --color",
    "lint:report": "yarn lint:js --format json -o sonar/report.json && yarn lint:css --formatter json --output-file sonar/report_css.json",
    "test": "vitest run --coverage",
    "test:dependencies": "depcheck",
    "test:integration": "vitest run .it --silent --coverage",
    "test:unit": "vitest run .unit --silent --coverage",
    "types": "tsc --project tsconfig.build.json --noEmit --skipLibCheck",
    "watch:esm": "yarn build:esm && (concurrently \"tsc --watch --project tsconfig.module.json\" \"tsc-alias -w -p tsconfig.module.json\")"
  }
}
