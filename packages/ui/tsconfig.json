{
  "extends": "@voiceflow/tsconfig",
  "compilerOptions": {
    "target": "es5",
    "jsx": "react",
    "downlevelIteration": true,
    "allowJs": true,
    "baseUrl": null,
    "lib": [
      "esnext",
      "dom"
    ],
    "typeRoots": [
      "../../node_modules/@types",
      "./typings"
    ],
    "types": [
      "node"
    ]
  },
  "compileOnSave": false,
  "exclude": [
    "node_modules/**",
    "build/**"
  ]
}
