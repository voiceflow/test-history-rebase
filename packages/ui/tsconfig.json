{
  "extends": "@voiceflow/tsconfig/web.json",
  "compilerOptions": {
    "target": "es2017",
    "checkJs": false,
    "skipLibCheck": true,
    "downlevelIteration": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@ui/*": ["src/*"]
    }
  },
  "exclude": ["node_modules/jest", "node_modules/**/*", "build/**/*", "coverage/**/*", "svgr.config.js"]
}
